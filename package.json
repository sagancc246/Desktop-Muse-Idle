{
  "name": "desktop-muse-idle",
  "private": true,
  "version": "0.1.0",
  "description": "A compact desktop idle game about collecting Memory from bouncing corner hits.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "verify:priority1": "electron scripts/priority1-regression.cjs",
    "verify:priority2": "electron scripts/priority2-collision-reward.cjs",
    "verify:priority3": "node scripts/verify-save-migrations.mjs",
    "verify:save-migrations": "node scripts/verify-save-migrations.mjs",
    "electron:dev": "concurrently -k -s first \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "electron:build": "npm run build && electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "pixi.js": "^8.9.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.7.2",
    "vite": "^6.1.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.desktopmuseidle.app",
    "productName": "Desktop Muse Idle",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false
    }
  }
}
